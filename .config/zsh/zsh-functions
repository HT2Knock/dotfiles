#!/usr/bin/zsh

function zsh_add_file() {
    [ -f "$ZDOTDIR/$1" ] && source "$ZDOTDIR/$1"
}

function start_ssh() {
    if [ -n "$SSH_AGENT_PID" ]; then
        echo "ssh-agent is already running"
    else
        eval $(ssh-agent -s)
    fi

    ssh-add $1 >/dev/null 2>&1
}

function mem_look() {
    free -h | awk '/Gi$/ {print $1, $3, "/", $2}'
}

function generate_empty_ssh() {
    [ -d $1 ] || mkdir -p $1

    ssh-keygen -b 2048 -t rsa -f $1 -q -N ""
}

function killport() {
    kill $(lsof -t -i :$1)
    echo "Port $1 killed"
}

function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

function f() {
    local selected
    selected=$(fzf --preview "bat --style=numbers --color=always --line-range :500 {}")
    [[ -n "$selected" ]] && nvim "$selected"
}

function calendar() {
    local file_path=~/workspace/github.com/T2Knock/JT-notes/calendar.txt

    if [[ ! -f "$file_path" ]]; then
        echo "Error: Calendar file not found at $file_path" >&2
        return 1
    fi

    local line_number=$(rg --line-number "$(date -I)" "$file_path" | cut -d: -f1 | head -n 1)

    nvim "$file_path" +$line_number
}

function get_git_root() {
    local root=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -n "$root" ]]; then
        echo "${root:t}"
    fi
}

function set_title() {
    local cmd_name="${1:-zsh}"
    local git_root=$(get_git_root)
    local path_display

    if [[ -n "$git_root" ]]; then
        path_display=" $git_root"
    else
        path_display=$(print -P "%3~")
    fi

    echo -ne "\e]2;${cmd_name} — ${path_display}\a"
}

preexec() {
    set_title "${1%% *}"
}

precmd() {
    set_title "zsh"
}
